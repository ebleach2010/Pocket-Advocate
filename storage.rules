rules_version = '2';

// Files live under cases/{caseId}/... — readable and writable only by the
// case's client and the admin. Uploads UI arrives in Phase 2; the rules are
// locked down from day one. 25 MB cap on client uploads (recordings and
// reports are uploaded by the admin).
service firebase.storage {
  match /b/{bucket}/o {

    function caseData(caseId) {
      return firestore.get(/databases/(default)/documents/cases/$(caseId)).data;
    }

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /cases/{caseId}/{allPaths=**} {
      allow read: if request.auth != null &&
        (caseData(caseId).clientUid == request.auth.uid || isAdmin());
      allow write: if request.auth != null &&
        (caseData(caseId).clientUid == request.auth.uid || isAdmin()) &&
        request.resource.size < 25 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
